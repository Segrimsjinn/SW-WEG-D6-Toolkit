    "class": {
      "index": "rogue",
      "name": "Rogue",
      "url": ""
    },
    "subclass": {
      "index": "arcane-trickster",
      "name": "Arcane Trickster",
      "url": ""
    },
    "desc": [
      "When you cast mage hand, you can make the spectral hand invisible, and you can perform the following additional tasks with it: stow one object the hand is holding in a container worn or carried by another creature; retrieve an object in a container worn or carried by another creature; or use thieves' tools to pick locks and disarm traps at range."
    ],
    "url": ""
  },
  {
    "index": "magical-ambush-arcane-trickster",
